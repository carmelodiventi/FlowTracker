{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flow Tracker",
  "version": "0.1.2",
  "identifier": "com.flowtracker.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Flow Tracker",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "visible": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/tray-icon.png"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}