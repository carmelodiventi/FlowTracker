{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities granted to the main Flow Tracker window.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:tray:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:scope-download",
    "fs:scope-home-recursive"
  ]
}